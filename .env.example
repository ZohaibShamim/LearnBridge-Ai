# Copy to .env and fill in. Used by docker-compose.yml.
# Mongo, Redis, and the service URLs are wired automatically by compose — you don't set them here.

# --- REQUIRED for the CV -> roadmap pipeline ---
# OpenAI key: https://platform.openai.com/api-keys
# This is the default provider (AI_PROVIDER below) — it's the only one that reliably fills in
# every roadmap step's "subtopics" (the guided-learning quizzes). Groq/HuggingFace still
# generate a roadmap, just without that guarantee — see docs/ai/services.md.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Cloudinary (CV file storage): https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# --- REQUIRED for login (OTP email) ---
# A Gmail address + an App Password (not your normal password) — generate one at
# https://myaccount.google.com/apppasswords. There is no fallback: if these are blank,
# login/signup will fail when it tries to email the one-time code.
EMAIL_USER=
EMAIL_PASSWORD=

# --- JWT secrets (any long random strings; defaults exist for local dev) ---
ACCESS_TOKEN_SECRET=change_me_access
REFRESH_TOKEN_SECRET=change_me_refresh
ACCESS_TOKEN_EXPIRY=1d
REFRESH_TOKEN_EXPIRY=10d

# --- OPTIONAL ---
# Switch provider: groq or huggingface also work, just without guaranteed subtopics.
AI_PROVIDER=openai
GROQ_API_KEY=
GROQ_MODEL=
SERPER_API_KEY=
YOUTUBE_API_KEY=
ROADMAP_TIMEOUT_MS=30000

# Browser -> backend URL baked into the frontend build. Change only if you remap the backend port.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8010/api/v1
