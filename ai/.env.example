# AI Provider Configuration
# Options: groq, huggingface, openai
AI_PROVIDER=groq

# Groq API Key (FREE & FAST - Get from https://console.groq.com/keys)
# Recommended: 14,400 requests/day free tier!
GROQ_API_KEY=your_groq_api_key_here

# Optional: Override default Groq model
# Default: llama-3.3-70b-versatile (fast and powerful)
# Other options: llama-3.1-8b-instant, mixtral-8x7b-32768
# GROQ_MODEL=llama-3.3-70b-versatile

# Hugging Face API Key (Alternative - Get from https://huggingface.co/settings/tokens)
HUGGINGFACE_API_KEY=your_huggingface_api_key_here

# Optional: Override default HuggingFace model
# HUGGINGFACE_MODEL=microsoft/Phi-3-mini-4k-instruct

# OpenAI API Key (Optional - for future use)
OPENAI_API_KEY=your_openai_api_key_here
